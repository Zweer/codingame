{
  "name": "codingame",
  "description": "Agent for solving CodinGame puzzles and managing the puzzle repository",
  "prompt": "file://../prompts/codingame.md",
  "resources": [
    "file://README.md",
    "file://.kiro/steering/**/*.md"
  ],
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": ["puzzle-solver"],
      "trustedAgents": ["puzzle-solver"]
    }
  }
}
